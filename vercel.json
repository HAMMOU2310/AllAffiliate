{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && curl -L https://github.com/eugeneware/ffmpeg-static/releases/download/b5.0.1/linux-x64 -o ffmpeg && chmod +x ffmpeg",
  "buildCommand": "export PATH=$PATH:$(pwd) && python build.py",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)\\.m3u8",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.apple.mpegurl"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*)\\.mp4",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/mp4"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
